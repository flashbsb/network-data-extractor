{
    "extractor": {
        "threads": 20,
        "randomize_order": true,
        "output_base_dir": "infos",
        "elements_file": "config/elements.cfg",
        "commands_file": "config/commands.cfg",
        "log_level": "INFO"
    },
    "ssh": {
        "timeout": 10,
        "delay_between_commands": 5
    },
    "topology": {
        "ignore_virtual_prefixes": [
            "Bundle",
            "PW",
            "NULL",
            "Null",
            "Loopback",
            "Tunnel",
            "BVI",
            "Vlan",
            "Port-channel",
            "Mgmt",
            "NVI"
        ],
        "neighbor_regex_prefixes": [
            "CONEXAO_COM_",
            "PEERING_",
            "TRUNK_"
        ],
        "speed_colors": {
            "1000000": {
                "width": 1,
                "color": "#800080"
            },
            "10000000": {
                "width": 2,
                "color": "#0085DA"
            },
            "100000000": {
                "width": 3,
                "color": "#006400"
            },
            "default": {
                "width": 4,
                "color": "#800080"
            }
        }
    }
}